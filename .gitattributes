# 所有文本文件统一使用 LF
* text=auto eol=lf

# 明确指定文本文件（必转 LF）
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.java text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.tex text eol=lf
*.sh text eol=lf

# 二进制文件不处理
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
